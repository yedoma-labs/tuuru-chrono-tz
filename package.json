{
  "name": "@yedoma-labs/tuuru-chrono-tz",
  "version": "0.1.0",
  "description": "TypeScript-first date/time library with built-in IANA timezone support. Immutable, zero-deps, <20KB.",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "date",
    "time",
    "datetime",
    "timezone",
    "tz",
    "iana",
    "world",
    "global",
    "immutable",
    "typescript",
    "chrono",
    "zero-dependency"
  ],
  "author": "yedoma-labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yedoma-labs/tuuru-chrono-tz"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "download-iana": "node scripts/download-iana.js",
    "parse-iana": "node scripts/parse-iana.js",
    "build-tzdata": "pnpm download-iana && pnpm parse-iana",
    "build": "tsc && tsc -p tsconfig.cjs.json && node -e \"require('node:fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'}))\" && node scripts/build-cdn.js",
    "build:cdn": "node scripts/build-cdn.js",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm clean && pnpm build",
    "pretest": "pnpm build",
    "test": "node --test test/datetime.test.js test/duration.test.js test/timezone.test.js test/locale.test.js test/locales.test.js test/calendar.test.js test/local.test.js test/exports.test.js test/security.test.js test/cjs.test.js",
    "size": "node scripts/check-size.js",
    "bench": "node scripts/benchmark.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "unpkg": "./dist/tuuru.min.js",
  "jsdelivr": "./dist/tuuru.min.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./tzdata": {
      "import": {
        "types": "./dist/esm/tzdata/index.d.ts",
        "default": "./dist/esm/tzdata/index.js"
      },
      "require": {
        "types": "./dist/cjs/tzdata/index.d.ts",
        "default": "./dist/cjs/tzdata/index.js"
      }
    },
    "./locales/*": {
      "import": {
        "types": "./dist/esm/locales/*.d.ts",
        "default": "./dist/esm/locales/*.js"
      },
      "require": {
        "types": "./dist/cjs/locales/*.d.ts",
        "default": "./dist/cjs/locales/*.js"
      }
    }
  }
}
